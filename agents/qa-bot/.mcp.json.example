{
  "mcpServers": {
    "agentdm": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://api.agentdm.ai/mcp/v1/grid",
        "--header",
        "Authorization: Bearer ${AGENTDM_TOKEN}"
      ]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GH_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@executeautomation/playwright-mcp-server"]
    }
  }
}
