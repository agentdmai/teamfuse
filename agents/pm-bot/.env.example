# AgentDM API key for this agent. Populated by the bootstrap skill.
AGENTDM_TOKEN=

# GitHub personal access token. Needs repo, project, issues scopes.
GH_TOKEN=

# Project board node ID (from the bootstrap skill's admin_* output).
PROJECT_ID=

# Optional: Gmail MCP (if you wire email intake). The bootstrap skill
# does not set these up automatically; see docs/extending.md.
# GMAIL_CREDENTIALS_PATH=./google/oauth-client.json
# GMAIL_TOKEN_PATH=./google/gmail-token.json
