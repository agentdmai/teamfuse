# SQLite file path (relative to agents-web/, or absolute).
DATABASE_URL=./data/control-plane.db

# Path to agents.config.json. Defaults to one level up from agents-web/
# (i.e. the repo root). Override if you keep the config elsewhere.
# AGENTS_CONFIG=../agents.config.json

# Dashboard bind. The control plane is local-only by design.
HOST=127.0.0.1
PORT=3005

# Optional: override the progress-bar caps on the usage panel.
# USAGE_CAP_5H=100000000
# USAGE_CAP_7D=2000000000
