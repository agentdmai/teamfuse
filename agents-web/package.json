{
  "name": "teamfuse-web",
  "version": "0.1.0",
  "private": true,
  "description": "teamfuse control panel. Starts, stops, wakes, and observes per-agent streaming Claude Code sessions from a local cabinet-style dashboard.",
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 3005",
    "build": "next build",
    "start": "next start -H 127.0.0.1 -p 3005",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "lucide-react": "^0.460.0",
    "next": "^16.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.1",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.17"
  }
}
